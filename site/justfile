# cascade site task runner -- `just <recipe>` (run `just` for the list)

set dotenv-load := true

# show all recipes
default:
    @just --list

# create .env from the example (won't overwrite an existing one)
setup:
    cp -n .env.example .env || true

# --- build / check ---
# The cascade stylesheet is rendered IN-MEMORY by the server via the cascade-css API (a workspace
# path dep, ../cascade-css); there is no CSS build/vendor step here.

# build the frontend bundle (vendors datastar, then Vite -> web/dist)
build-web:
    cd web && pnpm install && pnpm build

# full build: frontend -> server
build: build-web
    cargo build

check:
    cargo check

fmt:
    cargo fmt

clippy:
    cargo clippy --all-targets -- -D warnings

# --- run ---

# run the server (do `just build-web` first for the datastar/Pico bundle)
run:
    cargo run

# frontend dev: rebuild the Vite bundle on change (run alongside `just run`)
watch-web:
    cd web && pnpm watch
