# Rust build artifacts
/target

# Scratch build output. The shipped, committed DISTRIBUTION lives in /dist/<format> (see
# `cascade dist`) and is tracked; anything else written under /dist (e.g. an ad-hoc `cascade build
# --out dist`) is scratch and ignored. Typst ships its static faces under /dist/typst/fonts.
/dist/*
!/dist/css/
!/dist/typst/
!/dist/README.md

# Build bookkeeping (written into every --out dir)
.cascade-manifest.json
